<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ZiaMonitoring_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ZiaMonitoring_App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="ZiaBlack">#0D0A11</Color>
            <Color x:Key="ZiaPanel">#16111F</Color>
            <Color x:Key="ZiaPanelAlt">#1E162A</Color>
            <Color x:Key="ZiaPurple">#A64BFF</Color>
            <Color x:Key="ZiaViolet">#D478FF</Color>
            <Color x:Key="ZiaRed">#F23053</Color>
            <Color x:Key="ZiaText">#F7F4FF</Color>
            <Color x:Key="ZiaMuted">#B8A8D8</Color>

            <SolidColorBrush x:Key="ZiaBlackBrush" Color="{StaticResource ZiaBlack}" />
            <SolidColorBrush x:Key="ZiaPanelBrush" Color="{StaticResource ZiaPanel}" />
            <SolidColorBrush x:Key="ZiaPanelAltBrush" Color="{StaticResource ZiaPanelAlt}" />
            <SolidColorBrush x:Key="ZiaPurpleBrush" Color="{StaticResource ZiaPurple}" />
            <SolidColorBrush x:Key="ZiaVioletBrush" Color="{StaticResource ZiaViolet}" />
            <SolidColorBrush x:Key="ZiaRedBrush" Color="{StaticResource ZiaRed}" />
            <SolidColorBrush x:Key="ZiaTextBrush" Color="{StaticResource ZiaText}" />
            <SolidColorBrush x:Key="ZiaMutedBrush" Color="{StaticResource ZiaMuted}" />

            <LinearGradientBrush x:Key="ZiaBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#09070D" Offset="0" />
                <GradientStop Color="#150C1F" Offset="0.5" />
                <GradientStop Color="#1B0C18" Offset="1" />
            </LinearGradientBrush>

            <Style TargetType="TextBlock" x:Key="CardTitleTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaVioletBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="18" />
            </Style>

            <Style TargetType="Border" x:Key="CardStyle">
                <Setter Property="Background" Value="{StaticResource ZiaPanelBrush}" />
                <Setter Property="CornerRadius" Value="14" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="BorderBrush" Value="{StaticResource ZiaPanelAltBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="Button" x:Key="AccentButtonStyle">
                <Setter Property="Background" Value="{StaticResource ZiaPurpleBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
