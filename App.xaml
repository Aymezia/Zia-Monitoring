<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="ZiaMonitoring_App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:ZiaMonitoring_App.Converters"
    xmlns:local="using:ZiaMonitoring_App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- ============ Palette ============ -->
            <!-- Console terminal + silicium thermique : fond quasi noir chaud,
                 accent ambre phosphore unique, dégradé thermique reservé aux
                 données physiques reelles (charge/temperature), pas decoratif. -->
            <Color x:Key="ZiaBlack">#0A0906</Color>
            <Color x:Key="ZiaPanel">#100E0B</Color>
            <Color x:Key="ZiaPanelAlt">#171310</Color>
            <Color x:Key="ZiaStroke">#2B2318</Color>
            <Color x:Key="ZiaPurple">#E0A030</Color>
            <Color x:Key="ZiaViolet">#E0A030</Color>
            <Color x:Key="ZiaRed">#C0574A</Color>
            <Color x:Key="ZiaGreen">#8FAE72</Color>
            <Color x:Key="ZiaAmber">#D0973F</Color>
            <Color x:Key="ZiaText">#ECDCB8</Color>
            <Color x:Key="ZiaMuted">#8A7A5C</Color>
            <Color x:Key="ZiaDimmer">#5C5138</Color>

            <SolidColorBrush x:Key="ZiaBlackBrush" Color="{StaticResource ZiaBlack}" />
            <SolidColorBrush x:Key="ZiaPanelBrush" Color="{StaticResource ZiaPanel}" />
            <SolidColorBrush x:Key="ZiaPanelAltBrush" Color="{StaticResource ZiaPanelAlt}" />
            <SolidColorBrush x:Key="ZiaStrokeBrush" Color="{StaticResource ZiaStroke}" />
            <SolidColorBrush x:Key="ZiaPurpleBrush" Color="{StaticResource ZiaPurple}" />
            <SolidColorBrush x:Key="ZiaVioletBrush" Color="{StaticResource ZiaViolet}" />
            <SolidColorBrush x:Key="ZiaRedBrush" Color="{StaticResource ZiaRed}" />
            <SolidColorBrush x:Key="ZiaGreenBrush" Color="{StaticResource ZiaGreen}" />
            <SolidColorBrush x:Key="ZiaAmberBrush" Color="{StaticResource ZiaAmber}" />
            <SolidColorBrush x:Key="ZiaTextBrush" Color="{StaticResource ZiaText}" />
            <SolidColorBrush x:Key="ZiaMutedBrush" Color="{StaticResource ZiaMuted}" />
            <SolidColorBrush x:Key="ZiaDimmerBrush" Color="{StaticResource ZiaDimmer}" />

            <LinearGradientBrush x:Key="ZiaBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#080705" Offset="0" />
                <GradientStop Color="#100D09" Offset="0.5" />
                <GradientStop Color="#0A0906" Offset="1" />
            </LinearGradientBrush>

            <!-- Degrade thermique froid -> chaud, a utiliser uniquement pour des
                 grandeurs physiques reelles (charge CPU/GPU, temperature). Le
                 MappingMode Absolute permet de "reveler" une portion du degrade
                 en changeant juste la largeur de l'element peint (voir
                 PercentToPixelWidthConverter), plutot que de l'etirer. -->
            <LinearGradientBrush x:Key="ZiaThermalBrush" MappingMode="Absolute" StartPoint="0,0" EndPoint="160,0">
                <GradientStop Color="#3A6B9E" Offset="0" />
                <GradientStop Color="#2FB8A6" Offset="0.55" />
                <GradientStop Color="#D0973F" Offset="0.82" />
                <GradientStop Color="#C0574A" Offset="1" />
            </LinearGradientBrush>

            <!-- ============ Polices ============ -->
            <FontFamily x:Key="ZiaMonoFontFamily">Cascadia Mono, Consolas, monospace</FontFamily>

            <!-- ============ Convertisseurs ============ -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
            <conv:BoolToVisibilityConverter x:Key="BoolToVisInverse" Invert="True" />
            <conv:RiskLevelToBrushConverter x:Key="RiskToBrush" />
            <conv:BoolToStatusBrushConverter x:Key="PrivacyBrush" />
            <conv:AuditSeverityToBrushConverter x:Key="AuditSeverityToBrush" />
            <conv:PercentToPixelWidthConverter x:Key="PercentToWidth" />

            <!-- ============ Typographie ============ -->
            <Style TargetType="TextBlock" x:Key="PageTitleTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaTextBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="26" />
            </Style>

            <Style TargetType="TextBlock" x:Key="PageSubtitleTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaMutedBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Margin" Value="0,2,0,0" />
            </Style>

            <!-- Petit libellé de tuile KPI (majuscules fournies par le texte) -->
            <Style TargetType="TextBlock" x:Key="KpiLabelTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaMutedBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource ZiaMonoFontFamily}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="CharacterSpacing" Value="60" />
            </Style>

            <Style TargetType="TextBlock" x:Key="MetricValueTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaTextBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource ZiaMonoFontFamily}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="28" />
            </Style>

            <Style TargetType="TextBlock" x:Key="CaptionTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaMutedBrush}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <Style TargetType="TextBlock" x:Key="CardTitleTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaVioletBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="CharacterSpacing" Value="20" />
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <!-- Petit libellé technique (PID, chemin, identifiant) en mono, discret -->
            <Style TargetType="TextBlock" x:Key="MonoCaptionTextStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaMutedBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource ZiaMonoFontFamily}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!-- ============ Conteneurs ============ -->
            <Style TargetType="Border" x:Key="CardStyle">
                <Setter Property="Background" Value="{StaticResource ZiaPanelBrush}" />
                <Setter Property="CornerRadius" Value="0" />
                <Setter Property="Padding" Value="18" />
                <Setter Property="BorderBrush" Value="{StaticResource ZiaStrokeBrush}" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>

            <Style TargetType="Border" x:Key="KpiCardStyle" BasedOn="{StaticResource CardStyle}">
                <Setter Property="MinHeight" Value="168" />
                <Setter Property="Padding" Value="16,14" />
            </Style>

            <Style TargetType="Border" x:Key="BadgeStyle">
                <Setter Property="CornerRadius" Value="3" />
                <Setter Property="Padding" Value="10,4" />
                <Setter Property="HorizontalAlignment" Value="Center" />
            </Style>

            <Style TargetType="ProgressBar" x:Key="ZiaProgressBarStyle">
                <Setter Property="Foreground" Value="{StaticResource ZiaPurpleBrush}" />
                <Setter Property="Background" Value="{StaticResource ZiaStrokeBrush}" />
                <Setter Property="MinHeight" Value="6" />
                <Setter Property="CornerRadius" Value="0" />
            </Style>

            <Style TargetType="Button" x:Key="AccentButtonStyle">
                <Setter Property="Background" Value="{StaticResource ZiaPurpleBrush}" />
                <Setter Property="Foreground" Value="{StaticResource ZiaBlackBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="CornerRadius" Value="2" />
                <Setter Property="Padding" Value="12,8" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
