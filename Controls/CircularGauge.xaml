<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="ZiaMonitoring_App.Controls.CircularGauge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="Root"
        Width="116"
        Height="116">
        <Ellipse
            x:Name="Track"
            Width="86"
            Height="86"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Stroke="{StaticResource ZiaStrokeBrush}"
            StrokeThickness="6" />
        <Path
            x:Name="ArcPath"
            Stroke="{StaticResource ZiaPurpleBrush}"
            StrokeEndLineCap="Round"
            StrokeStartLineCap="Round"
            StrokeThickness="6" />
        <TextBlock
            x:Name="ValueText"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="21"
            FontWeight="SemiBold"
            Foreground="{StaticResource ZiaTextBrush}"
            TextAlignment="Center" />
    </Grid>
</UserControl>
