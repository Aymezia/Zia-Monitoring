<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.AssistancePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Assistance Zia" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="On le fait pour toi" Foreground="{StaticResource ZiaTextBrush}" FontSize="24" FontWeight="SemiBold" />
                <TextBlock Text="Generation d'un rapport support + session assistee ou premium." Foreground="{StaticResource ZiaMutedBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                    <Button Content="Exporter rapport diagnostic" Style="{StaticResource AccentButtonStyle}" Click="ExportReport_Click" />
                    <Button Content="Demander session assistee" Style="{StaticResource AccentButtonStyle}" Click="AssistedSession_Click" />
                    <Button Content="Demander session premium" Style="{StaticResource AccentButtonStyle}" Click="PremiumSession_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <ListView Grid.Row="2" ItemsSource="{Binding AssistedActions}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="18" />
                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ServiceLevelLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
