<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.BoostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BoostProgressBar" Storyboard.TargetProperty="Opacity" From="0.78" To="1" Duration="0:0:0.6" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Boost &amp; Optimisation" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Preview securise obligatoire avant execution." Foreground="{StaticResource ZiaMutedBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                    <Button Content="Mode Jeu" Style="{StaticResource AccentButtonStyle}" Click="GameMode_Click" />
                    <Button Content="Mode Travail" Style="{StaticResource AccentButtonStyle}" Click="WorkMode_Click" />
                    <Button Content="Rollback rapide" Style="{StaticResource AccentButtonStyle}" Click="Rollback_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="6">
                <TextBlock Text="Moteur d'optimisation" Style="{StaticResource CardTitleTextStyle}" />
                <TextBlock Text="{Binding OptimizationStageText}" Foreground="{StaticResource ZiaMutedBrush}" />
                <ProgressBar x:Name="BoostProgressBar" Minimum="0" Maximum="100" Value="{Binding OptimizationProgress}" Height="12" />
                <TextBlock Text="{Binding OptimizationProgressLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
            </StackPanel>
        </Border>

        <ListView Grid.Row="3" ItemsSource="{Binding BoostActions}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="18" />
                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RiskLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                            <TextBlock Text="{Binding RestartLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
