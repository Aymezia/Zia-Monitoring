<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.BoostPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Page.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="BoostProgressBar" Storyboard.TargetProperty="Opacity" From="0.78" To="1" Duration="0:0:0.6" />
        </Storyboard>
    </Page.Resources>

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Boost &amp; Optimisation" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="Preview securise obligatoire avant execution." Foreground="{StaticResource ZiaMutedBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                    <Button Content="Mode Jeu" Style="{StaticResource AccentButtonStyle}" Click="GameMode_Click" />
                    <Button Content="Mode Travail" Style="{StaticResource AccentButtonStyle}" Click="WorkMode_Click" />
                    <Button Content="Rollback rapide" Style="{StaticResource AccentButtonStyle}" Click="Rollback_Click" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="6">
                <TextBlock Text="Moteur d'optimisation" Style="{StaticResource CardTitleTextStyle}" />
                <TextBlock Text="{Binding OptimizationStageText}" Foreground="{StaticResource ZiaMutedBrush}" />
                <ProgressBar x:Name="BoostProgressBar" Minimum="0" Maximum="100" Value="{Binding OptimizationProgress}" Height="12" />
                <TextBlock Text="{Binding OptimizationProgressLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Programmes au démarrage" Style="{StaticResource CardTitleTextStyle}" />
                    <Button Grid.Column="1" Content="Actualiser" Click="RefreshStartup_Click" />
                </Grid>
                <TextBlock Text="Activation/désactivation via le mécanisme officiel (StartupApproved) — compatible avec le Gestionnaire des tâches." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                <ItemsControl x:Name="StartupList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" Margin="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DetailLabel}" Style="{StaticResource CaptionTextStyle}" />
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" VerticalAlignment="Center" FontWeight="SemiBold"
                                           Foreground="{Binding IsEnabled, Converter={StaticResource PrivacyBrush}}" />
                                <Button Grid.Column="2" Content="{Binding ToggleLabel}" Tag="{Binding}" Click="ToggleStartup_Click" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <ListView Grid.Row="4" ItemsSource="{Binding BoostActions}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="18" />
                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding RiskLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                            <TextBlock Text="{Binding RestartLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
