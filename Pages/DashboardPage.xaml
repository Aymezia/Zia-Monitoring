<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:controls="using:ZiaMonitoring_App.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24,20,24,24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- En-tête -->
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Dashboard temps réel" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Text="Surveillance live du processeur, de la mémoire, du réseau et des processus." Style="{StaticResource PageSubtitleTextStyle}" />
                </StackPanel>
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource CaptionTextStyle}"
                    Text="{Binding LastUpdateLabel}" />
            </Grid>

            <!-- Tuiles KPI -->
            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- CPU -->
                <Border Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="PROCESSEUR" Style="{StaticResource KpiLabelTextStyle}" />
                        <controls:CircularGauge Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Value="{Binding CpuPercent}" />
                        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{Binding CpuModel}" TextTrimming="CharacterEllipsis" MaxLines="1" />
                    </Grid>
                </Border>

                <!-- RAM -->
                <Border Grid.Column="1" Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="MÉMOIRE" Style="{StaticResource KpiLabelTextStyle}" />
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="10">
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource MetricValueTextStyle}" Text="{Binding MemoryPercentLabel}" />
                            <ProgressBar Style="{StaticResource ZiaProgressBarStyle}" Maximum="100" Value="{Binding MemoryPercent}" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{Binding MemoryDetailLabel}" />
                    </Grid>
                </Border>

                <!-- Température CPU -->
                <Border Grid.Column="2" Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="TEMPÉRATURE" Style="{StaticResource KpiLabelTextStyle}" />
                        <TextBlock Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource MetricValueTextStyle}" Text="{Binding CpuTempLabel}" />
                        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{Binding FanLabel}" />
                    </Grid>
                </Border>

                <!-- GPU -->
                <Border Grid.Column="3" Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="GPU" Style="{StaticResource KpiLabelTextStyle}" />
                        <controls:CircularGauge Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Value="{Binding GpuUsagePercent}" />
                        <StackPanel Grid.Row="2" HorizontalAlignment="Center" Orientation="Horizontal" Spacing="8">
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding GpuTempLabel}" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="•" />
                            <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding VramLabel}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Réseau -->
                <Border Grid.Column="4" Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="RÉSEAU" Style="{StaticResource KpiLabelTextStyle}" />
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock HorizontalAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource ZiaTextBrush}" Text="{Binding NetworkLabel}" TextWrapping="Wrap" TextAlignment="Center" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{Binding PingLabel}" />
                        </StackPanel>
                        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="{Binding DiskIoLabel}" />
                    </Grid>
                </Border>

                <!-- Santé -->
                <Border Grid.Column="5" Style="{StaticResource KpiCardStyle}">
                    <Grid RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="SANTÉ" Style="{StaticResource KpiLabelTextStyle}" />
                        <StackPanel Grid.Row="1" VerticalAlignment="Center" Spacing="10">
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource MetricValueTextStyle}" Text="{Binding HealthScoreLabel}" />
                            <Border Style="{StaticResource BadgeStyle}" Background="{Binding RiskLevel, Converter={StaticResource RiskToBrush}}">
                                <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ZiaBlackBrush}" Text="{Binding RiskLevel}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Grid.Row="2" HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="Score global du système" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Processus + alertes -->
            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Processus les plus gourmands" Style="{StaticResource CardTitleTextStyle}" />

                        <Grid Grid.Row="1" Padding="12,6" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="NOM" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock Grid.Column="1" Text="PID" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="MÉMOIRE" Style="{StaticResource KpiLabelTextStyle}" />
                        </Grid>

                        <ListView
                            Grid.Row="2"
                            MaxHeight="316"
                            IsItemClickEnabled="False"
                            ItemsSource="{Binding TopProcesses}"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="36" />
                                    <Setter Property="Padding" Value="12,0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="1" Text="{Binding Pid}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" HorizontalAlignment="Right" Text="{Binding MemoryLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Alertes" Style="{StaticResource CardTitleTextStyle}" />

                        <!-- État vide -->
                        <StackPanel
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8"
                            Visibility="{Binding NoAlerts, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="12" Height="12" HorizontalAlignment="Center" Fill="{StaticResource ZiaGreenBrush}" />
                            <TextBlock HorizontalAlignment="Center" Foreground="{StaticResource ZiaTextBrush}" FontWeight="SemiBold" Text="Aucune alerte active" />
                            <TextBlock HorizontalAlignment="Center" Style="{StaticResource CaptionTextStyle}" Text="Tout fonctionne normalement." />
                        </StackPanel>

                        <ItemsControl
                            Grid.Row="1"
                            ItemsSource="{Binding Alerts}"
                            Visibility="{Binding NoAlerts, Converter={StaticResource BoolToVisInverse}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,8"
                                        Padding="10,8"
                                        Background="{StaticResource ZiaPanelAltBrush}"
                                        BorderBrush="{StaticResource ZiaRedBrush}"
                                        BorderThickness="1,1,1,1"
                                        CornerRadius="8">
                                        <TextBlock FontSize="13" Foreground="{StaticResource ZiaTextBrush}" Text="{Binding}" TextWrapping="Wrap" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>

            <!-- Jeu actif -->
            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Ellipse
                        Width="10"
                        Height="10"
                        VerticalAlignment="Center"
                        Fill="{StaticResource ZiaGreenBrush}"
                        Visibility="{Binding IsGameActive, Converter={StaticResource BoolToVis}}" />
                    <Ellipse
                        Width="10"
                        Height="10"
                        VerticalAlignment="Center"
                        Fill="{StaticResource ZiaStrokeBrush}"
                        Visibility="{Binding IsGameActive, Converter={StaticResource BoolToVisInverse}}" />
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource ZiaTextBrush}" Text="{Binding ActiveGameLabel}" TextWrapping="Wrap" />
                        <TextBlock Style="{StaticResource CaptionTextStyle}" Text="{Binding ActiveGameServerLabel}" TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
