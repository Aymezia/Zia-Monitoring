<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.GamerSupportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="24,20,24,24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Gamer / Streamer" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="Diagnostics par jeu, rapports de session et temps de jeu." Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <!-- Sessions récentes + temps de jeu -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sessions récentes" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshSessionsButton" Content="Actualiser" Click="RefreshSessions_Click" />
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="WeeklyPlaytimeLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ListView Grid.Row="2" x:Name="SessionsList" MaxHeight="220" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="38" />
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DateLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding GameName}" Foreground="{StaticResource ZiaTextBrush}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding FpsLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding TempLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ComboBox x:Name="ProductCombo" Width="180" SelectedIndex="0">
                        <ComboBoxItem Content="Valorant" />
                        <ComboBoxItem Content="OBS" />
                    </ComboBox>
                    <TextBox x:Name="ErrorText" Width="360" PlaceholderText="Code erreur ou symptome (ex: VAN 9003, encoder overloaded)" />
                    <Button Content="Diagnostiquer" Style="{StaticResource AccentButtonStyle}" Click="Diagnose_Click" />
                    <Button Content="Auto Collect Logs" Style="{StaticResource AccentButtonStyle}" Click="AutoCollect_Click" />
                    <Button Content="1 clic correctif safe" Style="{StaticResource AccentButtonStyle}" Click="ApplyBestSafeFix_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Observations" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView x:Name="ObservationsList" MaxHeight="180" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Liens docs/web utiles" Style="{StaticResource CardTitleTextStyle}" />
                    <ItemsControl x:Name="SourcesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <HyperlinkButton Content="{Binding}" NavigateUri="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Solutions triées par probabilité" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView x:Name="SuggestionsList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ZiaPanelAltBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="16" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Why}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ConfidenceScore}" Foreground="{StaticResource ZiaVioletBrush}" />
                                        <TextBlock Text="{Binding ConfidenceLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                                        <TextBlock Text="{Binding SafeActionKey}" Foreground="{StaticResource ZiaRedBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
