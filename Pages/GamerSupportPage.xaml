<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.GamerSupportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="24,20,24,24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Gamer / Streamer" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="Diagnostics par jeu, rapports de session et temps de jeu." Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <!-- Sessions récentes + temps de jeu -->
            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Sessions récentes" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshSessionsButton" Content="Actualiser" Click="RefreshSessions_Click" />
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="WeeklyPlaytimeLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Grid.Row="1" HorizontalAlignment="Right" Orientation="Horizontal" Spacing="10">
                        <TextBlock x:Name="PresentMonStatusLabel" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                        <Button x:Name="InstallPresentMonButton" Content="Installer PresentMon (FPS réels)" Click="InstallPresentMon_Click" />
                    </StackPanel>
                    <ListView Grid.Row="2" x:Name="SessionsList" MaxHeight="220" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="MinHeight" Value="38" />
                                <Setter Property="Padding" Value="8,0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DateLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding GameName}" Foreground="{StaticResource ZiaTextBrush}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding DurationLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="3" Text="{Binding FpsLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="4" Text="{Binding TempLabel}" Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <ComboBox x:Name="ProductCombo" Width="200" SelectedIndex="0">
                        <ComboBoxItem Content="Valorant" />
                        <ComboBoxItem Content="Fortnite" />
                        <ComboBoxItem Content="CS2" />
                        <ComboBoxItem Content="Apex Legends" />
                        <ComboBoxItem Content="Rainbow Six Siege" />
                        <ComboBoxItem Content="League of Legends" />
                        <ComboBoxItem Content="DirectX" />
                        <ComboBoxItem Content="OBS" />
                    </ComboBox>
                    <TextBox x:Name="ErrorText" Width="360" PlaceholderText="Code erreur ou symptome (ex: VAN 9003, encoder overloaded)" />
                    <Button Content="Diagnostiquer" Style="{StaticResource AccentButtonStyle}" Click="Diagnose_Click" />
                    <Button Content="Auto Collect Logs" Style="{StaticResource AccentButtonStyle}" Click="AutoCollect_Click" />
                    <Button Content="1 clic correctif safe" Style="{StaticResource AccentButtonStyle}" Click="ApplyBestSafeFix_Click" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Observations" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView x:Name="ObservationsList" MaxHeight="180" />
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Liens docs/web utiles" Style="{StaticResource CardTitleTextStyle}" />
                    <ItemsControl x:Name="SourcesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <HyperlinkButton Content="{Binding}" NavigateUri="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Solutions triées par probabilité" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView x:Name="SuggestionsList">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ZiaPanelAltBrush}" CornerRadius="10" Padding="10" Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="16" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding Why}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ConfidenceScore}" Foreground="{StaticResource ZiaVioletBrush}" />
                                        <TextBlock Text="{Binding ConfidenceLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                                        <TextBlock Text="{Binding SafeActionKey}" Foreground="{StaticResource ZiaRedBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Preset graphique recommandé" Style="{StaticResource CardTitleTextStyle}" />
                        <Border Grid.Column="1" Style="{StaticResource BadgeStyle}" Background="{StaticResource ZiaPurpleBrush}">
                            <TextBlock x:Name="HardwareTierLabel" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </Grid>
                    <TextBlock Text="Recommandation générique selon votre palier matériel (VRAM, CPU, RAM) — pas un benchmark mesuré pour un jeu précis." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <Grid ColumnSpacing="20" RowSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="RÉSOLUTION" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetResolutionLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="TEXTURES" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetTextureLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="OMBRES" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetShadowLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="ANTI-ALIASING" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetAaLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="EFFETS" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetEffectsLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="FPS VISÉ" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="PresetFpsLabel" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                    <TextBlock x:Name="PresetNotesLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" Margin="0,4,0,0" />
                    <TextBlock x:Name="CompetitiveTipLabel" Foreground="{StaticResource ZiaAmberBrush}" FontSize="12" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="7" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Récap annuel" Style="{StaticResource CardTitleTextStyle}" />
                        <ComboBox x:Name="WrappedYearCombo" Grid.Column="1" Width="100" />
                        <Button Grid.Column="2" Content="Générer" Click="GenerateWrapped_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <TextBlock x:Name="WrappedStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <Grid x:Name="WrappedContent" ColumnSpacing="20" RowSpacing="10" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="TEMPS DE JEU TOTAL" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedPlaytimeLabel" Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="JEU LE PLUS JOUÉ" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedMostPlayedLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="15" TextWrapping="Wrap" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="SESSIONS" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedSessionsLabel" Style="{StaticResource MetricValueTextStyle}" />
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                            <TextBlock Text="FPS MOYEN" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedFpsLabel" Foreground="{StaticResource ZiaVioletBrush}" FontSize="15" FontWeight="SemiBold" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1">
                            <TextBlock Text="PIRE TEMPÉRATURE" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedTempLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="15" />
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="SESSION LA PLUS LONGUE" Style="{StaticResource KpiLabelTextStyle}" />
                            <TextBlock x:Name="WrappedLongestLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Lanceur unifie + inventaire anti-cheat -->
            <Border Grid.Row="8" Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="8">
                        <TextBlock Text="Lanceur rapide" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBox x:Name="LauncherSearchBox" PlaceholderText="Rechercher un jeu…" TextChanged="LauncherSearch_Changed" />
                        <ListView x:Name="LauncherList" MaxHeight="220" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Platform}" Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Lancer" Tag="{Binding}" Click="LaunchGame_Click" IsEnabled="{Binding HasLaunchUri}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="8">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Drivers anti-cheat détectés" Style="{StaticResource CardTitleTextStyle}" />
                            <Button Grid.Column="1" Content="Analyser" Click="ScanAntiCheat_Click" />
                        </Grid>
                        <TextBlock Text="Détection best-effort (nom de fichier/service connu) — transparence sur les accès noyau tiers, pas un outil de contournement." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        <ItemsControl x:Name="AntiCheatList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="10" Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                                            <TextBlock Text="{Binding Publisher}" Style="{StaticResource CaptionTextStyle}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Correlation chute de FPS -->
            <Border Grid.Row="9" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Chutes de FPS récentes" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" Content="Actualiser" Click="RefreshFpsDrops_Click" />
                    </Grid>
                    <TextBlock Text="Détection en temps réel (pas d'historique permanent) : note le process le plus gourmand en CPU au moment d'une chute nette de FPS." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="FpsDropList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Succes -->
            <Border Grid.Row="10" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Succès" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock x:Name="AchievementsSummaryLabel" Grid.Column="1" Foreground="{StaticResource ZiaVioletBrush}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <ItemsControl x:Name="AchievementsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding ProgressLabel}" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
