<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.HealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ZiaMonitoring_App.Controls"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <Grid Padding="24,20,24,24" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Santé globale" Style="{StaticResource PageTitleTextStyle}" />
                <TextBlock Text="Évaluation continue basée sur la charge CPU, la pression mémoire, les températures et les alertes." Style="{StaticResource PageSubtitleTextStyle}" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Spacing="8">
                        <TextBlock Text="{Binding HealthScoreLongLabel}" FontSize="34" FontWeight="SemiBold" Foreground="{StaticResource ZiaTextBrush}" />
                        <Border Style="{StaticResource BadgeStyle}" HorizontalAlignment="Left" Background="{Binding RiskLevel, Converter={StaticResource RiskToBrush}}">
                            <TextBlock FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource ZiaBlackBrush}" Text="{Binding RiskLevelLabel}" />
                        </Border>
                        <TextBlock Text="Le score agrège charge CPU, pression RAM, températures et alertes actives." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock HorizontalAlignment="Center" Text="PROCESSEUR" Style="{StaticResource KpiLabelTextStyle}" />
                        <controls:CircularGauge Value="{Binding CpuPercent}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Spacing="4">
                        <TextBlock HorizontalAlignment="Center" Text="GPU" Style="{StaticResource KpiLabelTextStyle}" />
                        <controls:CircularGauge Value="{Binding GpuUsagePercent}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CPU + GPU usage history -->
            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Historique CPU 24 h (moyennes horaires)" Style="{StaticResource CardTitleTextStyle}" />
                        <lvc:CartesianChart Height="200" LegendPosition="Hidden"
                            Series="{Binding Cpu24Series}" XAxes="{Binding Cpu24XAxes}" YAxes="{Binding CpuYAxes}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="GPU en temps réel" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Text="{Binding GpuUsageLabel}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource ZiaVioletBrush}" />
                        <lvc:CartesianChart Height="180" LegendPosition="Hidden"
                            Series="{Binding GpuSeries}" YAxes="{Binding GpuYAxes}" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Temperatures + Disk I/O -->
            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Températures CPU / GPU" Style="{StaticResource CardTitleTextStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <TextBlock Text="{Binding CpuTempLabel}" Foreground="{StaticResource ZiaTextBrush}" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding GpuTempLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="18" FontWeight="SemiBold" />
                        </StackPanel>
                        <lvc:CartesianChart Height="180" LegendPosition="Bottom"
                            Series="{Binding TempSeries}" YAxes="{Binding TempYAxes}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="I/O disque (échantillon par minute)" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Text="{Binding DiskIoLabel}" Style="{StaticResource CaptionTextStyle}" />
                        <lvc:CartesianChart Height="180" LegendPosition="Bottom"
                            Series="{Binding DiskIoSeries}" YAxes="{Binding DiskYAxes}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
