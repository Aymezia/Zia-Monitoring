<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.HealthPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Sante Globale" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <StackPanel>
                <TextBlock Text="{Binding HealthScoreLongLabel}" FontSize="34" Foreground="{StaticResource ZiaTextBrush}" />
                <TextBlock Text="{Binding HealthRiskLongLabel}" FontSize="18" Foreground="{StaticResource ZiaRedBrush}" />
                <TextBlock Text="L'evaluation se base sur charge CPU, pression RAM et alertes actives." Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Historique CPU 24h" Style="{StaticResource CardTitleTextStyle}" />
                    <lvc:CartesianChart
                        Height="240"
                        LegendPosition="Hidden"
                        Series="{Binding Cpu24Series}"
                        XAxes="{Binding Cpu24XAxes}"
                        YAxes="{Binding CpuYAxes}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Tendance CPU 7j" Style="{StaticResource CardTitleTextStyle}" />
                    <lvc:CartesianChart
                        Height="240"
                        LegendPosition="Hidden"
                        Series="{Binding Cpu7Series}"
                        XAxes="{Binding Cpu7XAxes}"
                        YAxes="{Binding CpuYAxes}" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
