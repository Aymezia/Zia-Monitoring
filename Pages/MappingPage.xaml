<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.MappingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Mapping PC" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="{Binding MachineLabel}" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock Grid.Row="1" Text="{Binding OsLabel}" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock Grid.Row="2" Text="{Binding ArchitectureLabel}" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock Grid.Row="3" Text="{Binding CpuLabel}" Foreground="{StaticResource ZiaTextBrush}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="4" Text="{Binding GpuLabel}" Foreground="{StaticResource ZiaTextBrush}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="5" Text="{Binding MotherboardLabel}" Foreground="{StaticResource ZiaTextBrush}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="6" Text="{Binding BiosLabel}" Foreground="{StaticResource ZiaTextBrush}" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="7" Text="{Binding InstalledRamLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                    <TextBlock Grid.Row="8" Text="{Binding TotalDiskLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                    <TextBlock Grid.Row="9" Text="{Binding UptimeLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                </Grid>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Stockage Detecte" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView ItemsSource="{Binding Disks}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding Format}" Foreground="{StaticResource ZiaMutedBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding FreeLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Jeux installes" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="{Binding GamesCountLabel}" Foreground="{StaticResource ZiaMutedBrush}" Margin="0,0,0,6" />
                    <GridView ItemsSource="{Binding InstalledGames}" MaxHeight="430" IsItemClickEnabled="False">
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="3" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border Width="190" MinHeight="265" Background="{StaticResource ZiaPanelAltBrush}" CornerRadius="8" Padding="10" Margin="0,0,10,10">
                                    <StackPanel Spacing="8">
                                        <Border Height="170" CornerRadius="6" Background="{StaticResource ZiaBlackBrush}">
                                            <Image Source="{Binding CoverImageUri}" Stretch="UniformToFill" />
                                        </Border>
                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" TextWrapping="Wrap" MaxLines="2" />
                                        <TextBlock Text="{Binding Platform}" Foreground="{StaticResource ZiaVioletBrush}" />
                                        <TextBlock Text="{Binding PlayTimeLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                                        <Button Content="Lancer" Tag="{Binding LaunchUri}" Click="LaunchGame_Click" Padding="8,4" HorizontalAlignment="Stretch" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Écrans — taux de rafraîchissement" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshDisplaysButton" Content="Vérifier" Click="RefreshDisplays_Click" />
                    </Grid>
                    <TextBlock Text="Détecte un écran resté en 60 Hz alors qu'il supporte un taux supérieur (144 Hz, G-Sync/FreeSync mal configuré, oubli après branchement)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="DisplaysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" FontSize="13" TextWrapping="Wrap" Margin="0,2"
                                           Foreground="{Binding IsHealthy, Converter={StaticResource PrivacyBrush}}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Résolution et HDR" Style="{StaticResource CardTitleTextStyle}" Margin="0,8,0,0" />
                    <ItemsControl x:Name="MonitorDetailsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="140" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding FriendlyName}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding ResolutionLabel}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="2" Text="{Binding HdrLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Manettes connectées" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshControllersButton" Content="Vérifier" Click="RefreshControllers_Click" />
                    </Grid>
                    <TextBlock Text="Xbox/compatibles (XInput) et manettes génériques (DualSense/DualShock...). Batterie affichée si le pilote l'expose." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="ControllersList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding Kind}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="2" Text="{Binding BatteryLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="ControllersStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Santé batterie" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshBatteryButton" Content="Analyser" Click="RefreshBattery_Click" />
                    </Grid>
                    <TextBlock Text="Usure réelle (capacité actuelle vs capacité d'origine) et cycles, via le rapport powercfg de Windows." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="BatteryList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="BatteryStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Grid.Row="7" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Diagnostic matériel avancé" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshHardwareDiagButton" Content="Analyser" Click="RefreshHardwareDiag_Click" />
                    </Grid>
                    <TextBlock Text="Profil XMP/EXPO, configuration mono/multi-canal de la RAM, bridage du lien PCIe du GPU (NVIDIA uniquement) et usure des SSD." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="MemorySpeedLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" />
                    <TextBlock x:Name="MemoryChannelLabel" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" />
                    <ItemsControl x:Name="PcieLinkList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl x:Name="SsdWearList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="HardwareDiagStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Bibliothèques Steam -->
            <Border Grid.Row="8" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Bibliothèques Steam par disque" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshSteamLibrariesButton" Content="Analyser" Click="RefreshSteamLibraries_Click" />
                    </Grid>
                    <TextBlock Text="Un gros jeu sur disque dur mécanique double ses temps de chargement. Cette carte montre quel jeu est sur quel disque et son type (SSD/HDD)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SteamLibrariesStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="SteamLibrariesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4" Spacing="2">
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Advice}" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Batterie Bluetooth -->
            <Border Grid.Row="9" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Batterie des périphériques Bluetooth" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="RefreshBluetoothButton" Content="Analyser" Click="RefreshBluetooth_Click" />
                    </Grid>
                    <TextBlock Text="Casque, souris, manette Bluetooth — le niveau de batterie que Windows cache dans un sous-menu. Tous les périphériques ne l'exposent pas." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="BluetoothList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="1" Text="{Binding BatteryLabel}" Foreground="{StaticResource ZiaVioletBrush}" FontFamily="{StaticResource ZiaMonoFontFamily}" FontSize="13" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock x:Name="BluetoothStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Testeur de drift manette -->
            <Border Grid.Row="10" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Testeur de drift de manette" Style="{StaticResource CardTitleTextStyle}" />
                        <ToggleSwitch x:Name="DriftTestToggle" OnContent="En direct" OffContent="Arrêté" Toggled="DriftTest_Toggled" />
                    </Grid>
                    <TextBlock Text="Lâchez les deux sticks : les points doivent rester au centre. S'ils dérivent tout seuls, un drift naissant est probable. Manettes XInput (Xbox et compatibles)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="24" HorizontalAlignment="Center">
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Border Width="120" Height="120" Background="{StaticResource ZiaPanelAltBrush}" BorderBrush="{StaticResource ZiaStrokeBrush}" BorderThickness="1">
                                <Canvas x:Name="LeftStickCanvas" Width="120" Height="120">
                                    <Ellipse Canvas.Left="56" Canvas.Top="56" Width="8" Height="8" Fill="{StaticResource ZiaMutedBrush}" />
                                    <Ellipse x:Name="LeftStickDot" Width="14" Height="14" Fill="{StaticResource ZiaVioletBrush}" Canvas.Left="53" Canvas.Top="53" />
                                </Canvas>
                            </Border>
                            <TextBlock Text="Stick gauche" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Spacing="4" HorizontalAlignment="Center">
                            <Border Width="120" Height="120" Background="{StaticResource ZiaPanelAltBrush}" BorderBrush="{StaticResource ZiaStrokeBrush}" BorderThickness="1">
                                <Canvas x:Name="RightStickCanvas" Width="120" Height="120">
                                    <Ellipse Canvas.Left="56" Canvas.Top="56" Width="8" Height="8" Fill="{StaticResource ZiaMutedBrush}" />
                                    <Ellipse x:Name="RightStickDot" Width="14" Height="14" Fill="{StaticResource ZiaVioletBrush}" Canvas.Left="53" Canvas.Top="53" />
                                </Canvas>
                            </Border>
                            <TextBlock Text="Stick droit" Style="{StaticResource CaptionTextStyle}" HorizontalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock x:Name="DriftStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
