<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Monitoring reseau" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding NetworkLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                    <TextBlock Text="{Binding ConnectionTypeLabel}" Foreground="{StaticResource ZiaVioletBrush}" />
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Ping serveurs jeux" Style="{StaticResource CardTitleTextStyle}" />
                        <lvc:CartesianChart Height="220" LegendPosition="Bottom" Series="{Binding GamePingSeries}" YAxes="{Binding PingYAxes}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Latence actuelle" Style="{StaticResource CardTitleTextStyle}" />
                        <ListView ItemsSource="{Binding GameServerLatencies}" MaxHeight="220">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="80" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Provider}" Foreground="{StaticResource ZiaTextBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Host}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="{Binding PingLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Processus reseau" Style="{StaticResource CardTitleTextStyle}" />
                    <ListView ItemsSource="{Binding TopNetworkProcesses}" MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="110" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Pid}" Foreground="{StaticResource ZiaMutedBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ProcessName}" Foreground="{StaticResource ZiaTextBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding ActiveConnections}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" />
                                    <TextBlock Grid.Column="3" Text="{Binding EstimatedKbpsLabel}" Foreground="{StaticResource ZiaMutedBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Connexions TCP actives" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="GeoLocateButton" Content="Géolocaliser les destinations" Click="GeoLocate_Click" />
                    </Grid>
                    <TextBlock x:Name="GeoStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="GeoResultsList" Margin="0,4,0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Ip}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="1" Text="{Binding GeoLabel}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Processes}" Style="{StaticResource CaptionTextStyle}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ListView ItemsSource="{Binding ActiveTcpConnections}" MaxHeight="360">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="150" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="120" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Pid}" Foreground="{StaticResource ZiaMutedBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding ProcessName}" Foreground="{StaticResource ZiaTextBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding LocalEndpoint}" Foreground="{StaticResource ZiaMutedBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding RemoteEndpoint}" Foreground="{StaticResource ZiaVioletBrush}" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding State}" Foreground="{StaticResource ZiaMutedBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Meilleure région (latence datacenters)" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="MeasureRegionsButton" Content="Mesurer les régions" Click="MeasureRegions_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <TextBlock Text="Latence vers les principales régions cloud (AWS) — la plupart des jeux y hébergent leurs serveurs. Recommandation seulement : aucune route n'est modifiée." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="RegionStatusLabel" Style="{StaticResource CaptionTextStyle}" />
                    <ItemsControl x:Name="RegionResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Region}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="1" Text="{Binding PingLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                    <Border Grid.Column="2" Style="{StaticResource BadgeStyle}" Background="{StaticResource ZiaGreenBrush}"
                                            Visibility="{Binding IsBest, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Recommandé" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ZiaBlackBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Perte de paquets" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="MeasurePacketLossButton" Content="Mesurer (rafale de 10 pings)" Click="MeasurePacketLoss_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <TextBlock Text="Complète la latence : une connexion peut sembler rapide en moyenne tout en perdant des paquets, source de micro-freezes en jeu." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="PacketLossStatusLabel" Style="{StaticResource CaptionTextStyle}" />
                    <ItemsControl x:Name="PacketLossResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="12" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Provider}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="1" Text="{Binding RttLabel}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="2" Text="{Binding LossLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Traceroute vers un serveur de jeu" Style="{StaticResource CardTitleTextStyle}" />
                        <ComboBox Grid.Column="1" x:Name="TracerouteTargetCombo" Width="140" SelectedIndex="0">
                            <ComboBoxItem Content="Riot" />
                            <ComboBoxItem Content="Valve" />
                            <ComboBoxItem Content="EA" />
                            <ComboBoxItem Content="Epic" />
                        </ComboBox>
                        <Button Grid.Column="2" x:Name="TracerouteButton" Content="Tracer" Click="Traceroute_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <TextBlock Text="Chemin réseau saut par saut (comme tracert) : repère si la latence augmente chez votre FAI ou plus loin, proche de la destination." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <TextBlock x:Name="TracerouteStatusLabel" Style="{StaticResource CaptionTextStyle}" />
                    <ItemsControl x:Name="TracerouteResultsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding HopNumber}" Style="{StaticResource CaptionTextStyle}" />
                                    <TextBlock Grid.Column="1" Text="{Binding AddressLabel}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="2" Text="{Binding RttLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="7" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="DNS et VPN" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="VpnStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <ComboBox x:Name="DnsProviderCombo" Width="220" SelectionChanged="DnsProvider_Changed" />
                        <ToggleSwitch x:Name="DohToggle" Header="DNS-over-HTTPS" Toggled="Doh_Toggled" />
                    </StackPanel>
                    <TextBlock x:Name="DnsStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <Button x:Name="MeasureDnsButton" Content="Comparer la latence des fournisseurs" Click="MeasureDns_Click" Style="{StaticResource AccentButtonStyle}" />
                    <ItemsControl x:Name="DnsLatencyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="90" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="1" Text="{Binding Ip}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" />
                                    <TextBlock Grid.Column="2" Text="{Binding RttLabel}" Foreground="{StaticResource ZiaVioletBrush}" HorizontalAlignment="Right" FontWeight="SemiBold" />
                                    <Border Grid.Column="3" Style="{StaticResource BadgeStyle}" Background="{StaticResource ZiaGreenBrush}"
                                            Visibility="{Binding IsBest, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Plus rapide" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource ZiaBlackBrush}" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="8" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Kill switch réseau par application" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Bloque tout le trafic sortant d'un exécutable via une règle de pare-feu Windows — réversible en un clic. L'application ciblée doit être relancée pour couper ses connexions déjà ouvertes." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="PickBlockTargetButton" Content="Choisir un exécutable à bloquer…" Click="PickBlockTarget_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="KillSwitchStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="BlockedAppsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1" Content="Débloquer" Tag="{Binding ExePath}" Click="UnblockApp_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
