<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.RecommendationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Text="Audit et recommandations" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center" Width="140">
                        <TextBlock x:Name="ScoreValueLabel" Text="—" FontFamily="{StaticResource ZiaMonoFontFamily}" FontSize="40" FontWeight="Bold" Foreground="{StaticResource ZiaTextBrush}" />
                        <TextBlock x:Name="ScoreQualifierLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    </StackPanel>

                    <StackPanel VerticalAlignment="Center" Spacing="4">
                        <TextBlock Text="Audit complet du PC" Style="{StaticResource CardTitleTextStyle}" />
                        <TextBlock Text="Agrège en une passe la sécurité, la confidentialité, le débloat, le démarrage, la stabilité et le matériel — et vous dit précisément quoi corriger en priorité." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                        <TextBlock x:Name="SummaryLabel" Foreground="{StaticResource ZiaVioletBrush}" FontWeight="SemiBold" />
                        <TextBlock x:Name="AuditStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    </StackPanel>

                    <Button Grid.Column="2" x:Name="RunAuditButton" Content="Lancer l'audit complet"
                            Style="{StaticResource AccentButtonStyle}" Click="RunAudit_Click" VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Grid Grid.Row="2" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Passez la souris sur une carte pour voir la recommandation associée." Style="{StaticResource CaptionTextStyle}" VerticalAlignment="Center" />
                <ComboBox Grid.Column="1" x:Name="CategoryFilterCombo" Width="200" SelectionChanged="CategoryFilter_Changed" SelectedIndex="0">
                    <ComboBoxItem Content="Toutes les catégories" />
                    <ComboBoxItem Content="Sécurité" />
                    <ComboBoxItem Content="Confidentialité" />
                    <ComboBoxItem Content="Stabilité" />
                    <ComboBoxItem Content="Matériel" />
                    <ComboBoxItem Content="Performance" />
                    <ComboBoxItem Content="Réseau" />
                </ComboBox>
            </Grid>

            <ItemsControl Grid.Row="3" x:Name="FindingsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <Grid ColumnSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="96" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{Binding Severity, Converter={StaticResource AuditSeverityToBrush}}" BorderThickness="1"
                                        Padding="8,3" HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding SeverityLabel}" FontFamily="{StaticResource ZiaMonoFontFamily}" FontSize="10.5" FontWeight="SemiBold"
                                               Foreground="{Binding Severity, Converter={StaticResource AuditSeverityToBrush}}" />
                                </Border>
                                <StackPanel Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{Binding CategoryLabel}" Foreground="{StaticResource ZiaMutedBrush}" FontFamily="{StaticResource ZiaMonoFontFamily}" FontSize="10.5" CharacterSpacing="40" />
                                    <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="16" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Detail}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                                    <TextBlock TextWrapping="Wrap">
                                        <Run Text="→ " Foreground="{StaticResource ZiaVioletBrush}" />
                                        <Run Text="{Binding Recommendation}" Foreground="{StaticResource ZiaTextBrush}" />
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </ScrollViewer>
</Page>
