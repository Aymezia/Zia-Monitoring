<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.RecommendationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Recommandations Upgrade" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />

        <ListView Grid.Row="1" ItemsSource="{Binding Recommendations}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="{Binding Priority}" Foreground="{StaticResource ZiaRedBrush}" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="18" />
                            <TextBlock Text="{Binding WhyLabel}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding SuggestionLabel}" Foreground="{StaticResource ZiaVioletBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="Impact estime: Moyen/Eleve | Cout estime: a confirmer" Foreground="{StaticResource ZiaMutedBrush}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
