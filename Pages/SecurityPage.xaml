<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.SecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Securite et Sante Systeme" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />
                <TextBlock Text="Analyse des risques, pilotes, S.M.A.R.T et securite Windows." Foreground="{StaticResource ZiaMutedBrush}" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Analyse de securite" Style="{StaticResource CardTitleTextStyle}" />
                    <Button x:Name="ScanButton" Content="Lancer l'analyse de securite" Click="Scan_Click" Style="{StaticResource AccentButtonStyle}" />
                    <TextBlock x:Name="ScanStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Etat Windows" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="FirewallLabel" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock x:Name="UacLabel" Foreground="{StaticResource ZiaTextBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="S.M.A.R.T - Sante des disques" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="SmartStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="SmartList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Pilotes obsoletes (&gt; 3 ans)" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="DriversStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="DriversList" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Demarrage - entrees suspectes" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="SuspiciousStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="SuspiciousList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
