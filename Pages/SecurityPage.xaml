<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.SecurityPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Securite et Sante Systeme" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />
                <TextBlock Text="Analyse des risques, pilotes, S.M.A.R.T et securite Windows." Foreground="{StaticResource ZiaMutedBrush}" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Analyse de securite" Style="{StaticResource CardTitleTextStyle}" />
                    <Button x:Name="ScanButton" Content="Lancer l'analyse de securite" Click="Scan_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Name="ExportSecurityButton" Content="Exporter rapport PDF / HTML" Click="ExportSecurity_Click" IsEnabled="False" />
                    <TextBlock x:Name="RiskScoreLabel" Foreground="{StaticResource ZiaRedBrush}" FontSize="22" />
                    <TextBlock x:Name="ScanStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Etat Windows" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="FirewallLabel" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock x:Name="UacLabel" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock x:Name="OpenPortsStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="OpenPortsList" MaxHeight="110" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="S.M.A.R.T - Sante des disques" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="SmartStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="SmartList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Pilotes obsoletes (&gt; 3 ans)" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="DriversStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="DriversList" MaxHeight="200">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Demarrage - entrees suspectes" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="SuspiciousStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="SuspiciousList" MaxHeight="120">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Signatures antivirus processus" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="SignatureStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="SignatureList" MaxHeight="150">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="7" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="6">
                    <TextBlock Text="Hooks clavier probables" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock x:Name="HookStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" />
                    <ListView x:Name="HookList" MaxHeight="150">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaRedBrush}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <Border Grid.Row="8" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Confidentialité Windows" Style="{StaticResource CardTitleTextStyle}" />
                        <Button Grid.Column="1" x:Name="FixAllPrivacyButton" Content="Tout corriger" Click="FixAllPrivacy_Click" Style="{StaticResource AccentButtonStyle}" />
                    </Grid>
                    <TextBlock Text="Traceurs et collectes de données activés par défaut (identifiant publicitaire, télémétrie d'usage, suggestions…)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="PrivacyList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="70" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Description}" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" VerticalAlignment="Center" FontWeight="SemiBold"
                                               Foreground="{Binding IsPrivacyFriendly, Converter={StaticResource PrivacyBrush}}" />
                                    <Button Grid.Column="2" Content="Corriger" Tag="{Binding Key}" Click="FixPrivacy_Click" VerticalAlignment="Center"
                                            Visibility="{Binding IsPrivacyFriendly, Converter={StaticResource BoolToVisInverse}}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="9" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Mot de passe compromis ? (HaveIBeenPwned)" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Vérification par k-anonymat : seuls les 5 premiers caractères du hash SHA-1 sont envoyés — jamais votre mot de passe." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <PasswordBox x:Name="HibpPasswordBox" Width="280" PlaceholderText="Mot de passe à vérifier" />
                        <Button x:Name="HibpCheckButton" Content="Vérifier" Click="CheckHibp_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="HibpResultLabel" TextWrapping="Wrap" Foreground="{StaticResource ZiaTextBrush}" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
