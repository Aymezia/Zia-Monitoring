<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="ZiaMonitoring_App.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Parametres" Style="{StaticResource TitleTextBlockStyle}" Foreground="{StaticResource ZiaTextBrush}" />
                <TextBox x:Name="SettingsSearchBox" PlaceholderText="Rechercher un réglage…" TextChanged="SettingsSearch_Changed" Margin="0,8,0,0" MaxWidth="420" HorizontalAlignment="Left" />
            </StackPanel>

            <!-- Monitoring -->
            <Border x:Name="MonitoringCard" Grid.Row="1" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Monitoring" Style="{StaticResource CardTitleTextStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Intervalle de rafraichissement (secondes):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" />
                        <Slider x:Name="RefreshSlider" Minimum="1" Maximum="10" StepFrequency="1" Width="200" ValueChanged="RefreshSlider_ValueChanged" />
                        <TextBlock x:Name="RefreshValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <ToggleSwitch x:Name="ToastToggle" Header="Alertes toast CPU / disque" Toggled="ToastToggle_Toggled" />
                    <ToggleSwitch x:Name="DailySummaryToggle" Header="Resume sante quotidien au demarrage" Toggled="DailySummary_Toggled" />
                    <TextBlock Text="Seuils d'alerte" Style="{StaticResource CardTitleTextStyle}" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Alerte CPU (%):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="170" />
                        <Slider x:Name="CpuAlertSlider" Minimum="50" Maximum="100" StepFrequency="5" Width="200" ValueChanged="CpuAlertSlider_ValueChanged" />
                        <TextBlock x:Name="CpuAlertValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Alerte temperature CPU (°C):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="170" />
                        <Slider x:Name="CpuTempAlertSlider" Minimum="50" Maximum="105" StepFrequency="1" Width="200" ValueChanged="CpuTempAlertSlider_ValueChanged" />
                        <TextBlock x:Name="CpuTempAlertValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Alerte temperature GPU (°C):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="170" />
                        <Slider x:Name="GpuTempAlertSlider" Minimum="50" Maximum="105" StepFrequency="1" Width="200" ValueChanged="GpuTempAlertSlider_ValueChanged" />
                        <TextBlock x:Name="GpuTempAlertValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Alerte disque plein (GB libres):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="170" />
                        <Slider x:Name="DiskAlertSlider" Minimum="1" Maximum="100" StepFrequency="1" Width="200" ValueChanged="DiskAlertSlider_ValueChanged" />
                        <TextBlock x:Name="DiskAlertValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Objectif temps de jeu hebdo (h):" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="170" />
                        <Slider x:Name="PlaytimeGoalSlider" Minimum="0" Maximum="60" StepFrequency="1" Width="200" ValueChanged="PlaytimeGoalSlider_ValueChanged" />
                        <TextBlock x:Name="PlaytimeGoalValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Systeme -->
            <Border x:Name="SystemCard" Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Systeme" Style="{StaticResource CardTitleTextStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Langue :" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="120" />
                        <ComboBox x:Name="LanguageCombo" Width="160" SelectionChanged="Language_Changed">
                            <ComboBoxItem Content="Français" Tag="fr-FR" />
                            <ComboBoxItem Content="English" Tag="en-US" />
                        </ComboBox>
                    </StackPanel>
                    <TextBlock Text="Redémarrage de l'application requis pour changer de langue. Traduction actuellement limitée au menu de navigation." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="SystrayToggle" Header="Icone systray avec tooltip CPU / GPU live" Toggled="Systray_Toggled" />
                    <ToggleSwitch x:Name="AutoStartToggle" Header="Demarrer automatiquement avec Windows" Toggled="AutoStart_Toggled" />
                    <ToggleSwitch x:Name="HotkeyToggle" Header="Raccourci global Ctrl+Shift+Z" Toggled="Hotkey_Toggled" />
                    <ToggleSwitch x:Name="OverlayToggle" Header="Overlay in-game CPU / GPU / FPS" Toggled="Overlay_Toggled" />
                    <ToggleSwitch x:Name="MiniWidgetToggle" Header="Widget mini toujours au premier plan" Toggled="MiniWidget_Toggled" />
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Transparence widget:" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" />
                        <Slider x:Name="MiniOpacitySlider" Minimum="35" Maximum="100" StepFrequency="5" Width="200" ValueChanged="MiniOpacitySlider_ValueChanged" />
                        <TextBlock x:Name="MiniOpacityValueLabel" Foreground="{StaticResource ZiaVioletBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Thème du widget:" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="120" />
                        <ComboBox x:Name="WidgetThemeCombo" Width="160" SelectionChanged="WidgetTheme_Changed">
                            <ComboBoxItem Content="Violet" Tag="Violet" />
                            <ComboBoxItem Content="Cyan" Tag="Cyan" />
                            <ComboBoxItem Content="Vert" Tag="Green" />
                            <ComboBoxItem Content="Ambre" Tag="Amber" />
                            <ComboBoxItem Content="Rose" Tag="Rose" />
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Écran de l'overlay:" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="120" />
                        <ComboBox x:Name="OverlayMonitorCombo" Width="220" SelectionChanged="OverlayPosition_Changed" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="Position:" Foreground="{StaticResource ZiaTextBrush}" VerticalAlignment="Center" Width="120" />
                        <ComboBox x:Name="OverlayCornerCombo" Width="220" SelectionChanged="OverlayPosition_Changed">
                            <ComboBoxItem Content="Haut gauche" Tag="TopLeft" />
                            <ComboBoxItem Content="Haut droite" Tag="TopRight" />
                            <ComboBoxItem Content="Bas gauche" Tag="BottomLeft" />
                            <ComboBoxItem Content="Bas droite" Tag="BottomRight" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Jeux & Optimisation -->
            <Border x:Name="GamesOptimizationCard" Grid.Row="3" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Jeux et optimisation" Style="{StaticResource CardTitleTextStyle}" />
                    <ToggleSwitch x:Name="GameBoosterToggle" Header="Game Booster automatique (priorités + plan d'alimentation performances, restaurés en fin de partie)" Toggled="GameBooster_Toggled" />
                    <ToggleSwitch x:Name="RestorePointToggle" Header="Point de restauration Windows avant Boost/Débloat" Toggled="RestorePoint_Toggled" />
                    <ToggleSwitch x:Name="SilentModeToggle" Header="Mode silencieux automatique quand un jeu est detecte" Toggled="SilentMode_Toggled" />
                    <ToggleSwitch x:Name="SchedulerToggle" Header="Nettoyage temp planifie (3h du matin)" Toggled="Scheduler_Toggled" />
                    <ToggleSwitch x:Name="SaveBackupToggle" Header="Sauvegarde quotidienne des saves de jeux (My Games + Saved Games, même heure)" Toggled="SaveBackup_Toggled" />
                    <Button Content="Desactiver animations Windows (optimisation maximale)" Click="DisableAnimations_Click" Style="{StaticResource AccentButtonStyle}" />
                    <Button Content="Restaurer animations Windows" Click="RestoreAnimations_Click" />
                </StackPanel>
            </Border>

            <!-- Export -->
            <Border x:Name="ExportCard" Grid.Row="4" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Export et rapports" Style="{StaticResource CardTitleTextStyle}" />
                    <Button x:Name="ExportPdfButton" Content="Exporter rapport HTML (ouvrir dans navigateur)" Click="ExportHtml_Click" Style="{StaticResource AccentButtonStyle}" />
                    <TextBlock x:Name="ExportStatusLabel" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Historique Boost -->
            <Border x:Name="BoostHistoryCard" Grid.Row="5" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Historique des optimisations" Style="{StaticResource CardTitleTextStyle}" />
                    <Button Content="Rafraichir l'historique" Click="RefreshHistory_Click" />
                    <ListView x:Name="HistoryList" MaxHeight="260">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="160" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding AppliedAt}" Foreground="{StaticResource ZiaMutedBrush}" />
                                    <TextBlock Grid.Column="1" Text="{Binding HealthScoreBefore}" Foreground="{StaticResource ZiaVioletBrush}" />
                                    <TextBlock Grid.Column="2" Text="{Binding HealthScoreAfter}" Foreground="{StaticResource ZiaTextBrush}" />
                                    <TextBlock Grid.Column="3" Text="{Binding ActionsLabel}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>

            <!-- Export historique -->
            <Border x:Name="MetricsExportCard" Grid.Row="6" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Export de l'historique des métriques" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Échantillons bruts (CPU, RAM, températures) des 8 derniers jours, pour analyse externe (Excel, Python...)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button x:Name="ExportCsvButton" Content="Exporter en CSV" Click="ExportCsv_Click" />
                        <Button x:Name="ExportJsonButton" Content="Exporter en JSON" Click="ExportJson_Click" />
                    </StackPanel>
                    <TextBlock x:Name="ExportHistoryStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Sauvegarde des saves de jeux -->
            <Border x:Name="SaveBackupCard" Grid.Row="7" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sauvegarde des saves de jeux" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Zip de Documents\My Games et %USERPROFILE%\Saved Games — les deux conventions les plus répandues. 7 dernières sauvegardes conservées." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <Button x:Name="BackupNowButton" Content="Sauvegarder maintenant" Click="BackupNow_Click" Style="{StaticResource AccentButtonStyle}" />
                    <TextBlock x:Name="BackupStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Règles personnalisées -->
            <Border x:Name="CustomRulesCard" Grid.Row="8" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Règles personnalisées" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Ex : CPU au-dessus de 90% pendant 10 min → nettoyage temp. Une alerte au maximum toutes les 15 min par règle." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBox x:Name="RuleNameBox" Width="120" PlaceholderText="Nom" />
                        <ComboBox x:Name="RuleConditionCombo" Width="180" SelectedIndex="0">
                            <ComboBoxItem Content="CPU au-dessus de (%)" Tag="CpuAbove" />
                            <ComboBoxItem Content="RAM au-dessus de (%)" Tag="RamAbove" />
                            <ComboBoxItem Content="Temp. CPU au-dessus de (°C)" Tag="CpuTempAbove" />
                            <ComboBoxItem Content="Temp. GPU au-dessus de (°C)" Tag="GpuTempAbove" />
                            <ComboBoxItem Content="Disque C: libre sous (GB)" Tag="DiskFreeBelow" />
                        </ComboBox>
                        <TextBox x:Name="RuleThresholdBox" Width="60" PlaceholderText="Seuil" />
                        <TextBox x:Name="RuleMinutesBox" Width="55" PlaceholderText="Min." />
                        <ComboBox x:Name="RuleActionCombo" Width="180" SelectedIndex="0">
                            <ComboBoxItem Content="Notifier seulement" Tag="Notify" />
                            <ComboBoxItem Content="Nettoyage temp" Tag="RunDeepClean" />
                            <ComboBoxItem Content="Ouvrir Gestionnaire des tâches" Tag="OpenTaskManager" />
                        </ComboBox>
                        <Button Content="Ajouter" Click="AddRule_Click" Style="{StaticResource AccentButtonStyle}" />
                    </StackPanel>
                    <TextBlock x:Name="RuleStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ItemsControl x:Name="CustomRulesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="10" Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" />
                                    <Button Grid.Column="1" Content="Supprimer" Tag="{Binding Id}" Click="RemoveRule_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Export Prometheus -->
            <Border x:Name="PrometheusCard" Grid.Row="9" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Export Prometheus" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Expose les métriques courantes sur http://localhost:9877/metrics pour un Grafana local. Accessible uniquement depuis cette machine." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="PrometheusToggle" Header="Activer l'export Prometheus" Toggled="Prometheus_Toggled" />
                    <TextBlock x:Name="PrometheusStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- OBS WebSocket -->
            <Border x:Name="ObsCard" Grid.Row="10" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Bascule de scène OBS automatique" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Nécessite OBS Studio 28+ avec le serveur WebSocket activé (Outils → Paramètres du serveur WebSocket). Bascule vers la scène 'Jeu' à la détection d'un jeu, vers 'Repos' à sa fermeture." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="ObsToggle" Header="Activer la bascule automatique" Toggled="Obs_Toggled" />
                    <Grid ColumnSpacing="10" RowSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="ObsHostBox" PlaceholderText="Hôte (localhost)" TextChanged="ObsFields_Changed" />
                        <TextBox Grid.Column="1" x:Name="ObsPortBox" PlaceholderText="Port (4455)" TextChanged="ObsFields_Changed" />
                        <PasswordBox Grid.Row="1" x:Name="ObsPasswordBox" PlaceholderText="Mot de passe (si activé dans OBS)" PasswordChanged="ObsPassword_Changed" />
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Tester la connexion" Click="TestObsConnection_Click" />
                        </StackPanel>
                    </Grid>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ObsGameSceneBox" PlaceholderText="Scène 'Jeu'" TextChanged="ObsFields_Changed" />
                        <TextBox Grid.Column="1" x:Name="ObsIdleSceneBox" PlaceholderText="Scène 'Repos'" TextChanged="ObsFields_Changed" />
                    </Grid>
                    <TextBlock x:Name="ObsStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Capteurs materiels avances -->
            <Border x:Name="HardwareSensorsCard" Grid.Row="11" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Capteurs materiels avances (temperatures / ventilateurs)" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Desactive par defaut. L'activation installe un driver bas niveau (LibreHardwareMonitor / WinRing0) pour lire les temperatures CPU/GPU et la vitesse des ventilateurs. Ce driver figure sur la liste des drivers vulnerables de Microsoft : Windows Defender peut le detecter et le supprimer automatiquement, ce qui desactivera de nouveau ces mesures. N'activez que si vous comprenez ce risque." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="HardwareSensorsToggle" Header="Activer les capteurs materiels avances" Toggled="HardwareSensors_Toggled" />
                </StackPanel>
            </Border>

            <!-- Profils de lancement par jeu -->
            <Border x:Name="GameLaunchProfilesCard" Grid.Row="12" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Profils de lancement par jeu" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Au demarrage d'un jeu configure : lance des applications compagnon (Discord, OBS...) et arrete des process indesirables, une seule fois (pas de surveillance continue)." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <ToggleSwitch x:Name="GameLaunchProfilesToggle" Header="Activer les profils de lancement" Toggled="GameLaunchProfiles_Toggled" />
                    <ToggleSwitch x:Name="ClipboardClearToggle" Header="Vider le presse-papiers au lancement d'un jeu" Toggled="ClipboardClear_Toggled" />

                    <TextBox x:Name="ProfileGameNameBox" PlaceholderText="Nom du process du jeu (ex: VALORANT-Win64-Shipping)" Margin="0,8,0,0" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Ajouter appli compagnon…" Click="AddCompanionApp_Click" />
                        <TextBox x:Name="KillProcessBox" Width="180" PlaceholderText="Process a tuer (ex: chrome)" />
                        <Button Content="Ajouter" Click="AddKillProcess_Click" />
                    </StackPanel>
                    <ItemsControl x:Name="PendingCompanionAppsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaMutedBrush}" FontSize="13" TextTrimming="CharacterEllipsis" />
                                    <Button Grid.Column="1" Content="×" Tag="{Binding}" Click="RemoveCompanionApp_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl x:Name="PendingKillList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding}" Foreground="{StaticResource ZiaVioletBrush}" FontSize="13" />
                                    <Button Grid.Column="1" Content="×" Tag="{Binding}" Click="RemoveKillProcess_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="Enregistrer le profil" Click="SaveGameProfile_Click" Style="{StaticResource AccentButtonStyle}" />
                    <TextBlock x:Name="GameProfileStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />

                    <TextBlock Text="Profils enregistrés" Style="{StaticResource CardTitleTextStyle}" Margin="0,8,0,0" />
                    <ItemsControl x:Name="SavedProfilesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnSpacing="8" Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" Foreground="{StaticResource ZiaTextBrush}" FontSize="13" TextWrapping="Wrap" />
                                    <Button Grid.Column="1" Content="Supprimer" Tag="{Binding GameProcessName}" Click="DeleteGameProfile_Click" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Sauvegarde complete des reglages -->
            <Border x:Name="SettingsBackupCard" Grid.Row="13" Style="{StaticResource CardStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Sauvegarde complète des réglages" Style="{StaticResource CardTitleTextStyle}" />
                    <TextBlock Text="Exporte ou restaure tous les paramètres de l'application (pas seulement les profils Boost) — utile pour revenir en arrière après un essai, ou dupliquer la config sur ce même compte Windows. La clé API et le mot de passe OBS restent chiffrés (DPAPI, lié à ce compte Windows) : ils ne seront pas restaurés si le fichier est importé sur une autre machine ou un autre compte." Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Exporter les réglages…" Click="ExportSettings_Click" Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Importer des réglages…" Click="ImportSettings_Click" />
                    </StackPanel>
                    <TextBlock x:Name="SettingsBackupStatusLabel" Style="{StaticResource CaptionTextStyle}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
