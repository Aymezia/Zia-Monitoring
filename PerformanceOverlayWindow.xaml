<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="ZiaMonitoring_App.PerformanceOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Zia Live">

    <Grid
        x:Name="Root"
        Width="260"
        Padding="14"
        Background="{StaticResource ZiaPanelBrush}">
        <StackPanel Spacing="8">
            <TextBlock Text="Zia Live" Style="{StaticResource CardTitleTextStyle}" />

            <Grid ColumnSpacing="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="CPU" Foreground="{StaticResource ZiaMutedBrush}" />
                    <TextBlock Text="{Binding CpuPercentLabel}" FontSize="24" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock Text="{Binding CpuTempLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="GPU" Foreground="{StaticResource ZiaMutedBrush}" />
                    <TextBlock Text="{Binding GpuUsageLabel}" FontSize="24" Foreground="{StaticResource ZiaTextBrush}" />
                    <TextBlock Text="{Binding GpuTempLabel}" Foreground="{StaticResource ZiaMutedBrush}" />
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding EstimatedFpsLabel}" FontSize="20" Foreground="{StaticResource ZiaVioletBrush}" />
            <TextBlock Text="{Binding NetworkLabel}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
            <TextBlock Text="{Binding ActiveGameServerLabel}" Foreground="{StaticResource ZiaMutedBrush}" TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
